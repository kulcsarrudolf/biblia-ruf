{
  "name": "biblia-ruf",
  "version": "2.0.6",
  "description": "RÚF Biblia — Revideált új fordítás library and CLI tool",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "bin/**/*",
    "json/**/*",
    "README.md"
  ],
  "bin": {
    "biblia": "./bin/biblia.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate": "node -e \"require('./dist/utils/validate').validateAllBooks()\"",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "yarn build && changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kulcsarrudolf/biblia-ruf.git"
  },
  "author": "Kulcsar Rudolf",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kulcsarrudolf/biblia-ruf/issues"
  },
  "homepage": "https://github.com/kulcsarrudolf/biblia-ruf#readme",
  "keywords": [
    "bible",
    "biblia",
    "ruf",
    "hungarian",
    "magyar",
    "reformed",
    "cli"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.4.2",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "ts-jest": "^29.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.1.6",
    "typescript-eslint": "^8.62.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
