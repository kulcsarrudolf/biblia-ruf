{
  "name": "biblia-ruf",
  "version": "2.0.5",
  "description": "RÚF Biblia — Revideált új fordítás library and CLI tool",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "bin/**/*",
    "json/**/*",
    "README.md"
  ],
  "bin": {
    "biblia": "./bin/biblia.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prebuild": "shx rm -rf dist",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "validate": "node -e \"require('./dist/utils/validate').validateAllBooks()\"",
    "prepare": "husky",
    "release": "bash scripts/release.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kulcsarrudolf/biblia-ruf.git"
  },
  "author": "Kulcsar Rudolf",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kulcsarrudolf/biblia-ruf/issues"
  },
  "homepage": "https://github.com/kulcsarrudolf/biblia-ruf#readme",
  "keywords": [
    "bible",
    "biblia",
    "ruf",
    "hungarian",
    "magyar",
    "reformed",
    "cli"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.4.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "shx": "^0.3.4",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.6"
  },
  "lint-staged": {
    "*.ts": "prettier --write"
  }
}
